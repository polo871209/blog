---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const logs = (await getCollection("logs")).map((p) => ({ p, section: "logs" }));
  const misc = (await getCollection("misc")).map((p) => ({ p, section: "misc" }));
  const all = [...logs, ...misc];

  const tags = new Set<string>();
  all.forEach(({ p }) => p.data.tags.forEach((t) => tags.add(t)));

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: all
        .filter(({ p }) => p.data.tags.includes(tag))
        .sort((a, b) => b.p.data.date.getTime() - a.p.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
const iso = (d: Date) => d.toISOString().slice(0, 10);
---
<BaseLayout title={`#${tag}`}>
  <section class="list">
    <h2 class="term-head">#{tag}</h2>
    <ul class="post-list">
      {posts.map(({ p, section }) => (
        <li>
          <a href={`/${section}/${p.id}/`}>
            <time datetime={iso(p.data.date)}>{iso(p.data.date)}</time>
            <span class="post-title">{p.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
