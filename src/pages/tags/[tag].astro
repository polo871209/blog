---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { titleOf, iso } from "../../lib/posts";

export async function getStaticPaths() {
  const logs = (await getCollection("logs")).map((p) => ({ p, section: "logs" }));
  const misc = (await getCollection("misc")).map((p) => ({ p, section: "misc" }));
  const all = [...logs, ...misc];

  const tags = new Set<string>();
  all.forEach(({ p }) => p.data.tags.forEach((t) => tags.add(t)));

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: all
        .filter(({ p }) => p.data.tags.includes(tag))
        .sort(
          (a, b) =>
            (b.p.data.date?.getTime() ?? 0) - (a.p.data.date?.getTime() ?? 0),
        ),
    },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`}>
  <section class="list">
    <h2 class="term-head">#{tag}</h2>
    <ul class="post-list">
      {posts.map(({ p, section }) => (
        <li>
          <a href={`/${section}/${p.id}/`}>
            {p.data.date && <time datetime={iso(p.data.date)}>{iso(p.data.date)}</time>}
            <span class="post-title">{titleOf(p)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
