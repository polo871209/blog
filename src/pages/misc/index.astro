---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("misc")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const iso = (d: Date) => d.toISOString().slice(0, 10);
---
<BaseLayout title="Misc" section="misc">
  <section class="list">
    <div class="prose lede"><p>Things that don't fit anywhere else.</p></div>
    <ul class="post-list">
      {posts.map((p) => (
        <li>
          <a href={`/misc/${p.id}/`}>
            <time datetime={iso(p.data.date)}>{iso(p.data.date)}</time>
            <span class="post-title">{p.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
