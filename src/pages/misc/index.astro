---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { titleOf, byDateDesc, iso } from "../../lib/posts";

const posts = (await getCollection("misc")).sort(byDateDesc);
---
<BaseLayout title="Misc" section="misc">
  <section class="list">
    <div class="prose lede"><p>Things that don't fit anywhere else.</p></div>
    <ul class="post-list">
      {posts.map((p) => (
        <li>
          <a href={`/misc/${p.id}/`}>
            {p.data.date && <time datetime={iso(p.data.date)}>{iso(p.data.date)}</time>}
            <span class="post-title">{titleOf(p)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
