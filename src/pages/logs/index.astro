---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("logs")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const iso = (d: Date) => d.toISOString().slice(0, 10);
---
<BaseLayout title="Logs" section="logs">
  <section class="list">
    <div class="prose lede"><p>Just sharing the simple solutions that work.</p></div>
    <ul class="post-list">
      {posts.map((p) => (
        <li>
          <a href={`/logs/${p.id}/`}>
            <time datetime={iso(p.data.date)}>{iso(p.data.date)}</time>
            <span class="post-title">{p.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
