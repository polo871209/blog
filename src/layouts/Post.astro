---
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import Toc from "../components/Toc.astro";
import Giscus from "../components/Giscus.astro";
import { titleOf, iso } from "../lib/posts";

interface Props {
  post: CollectionEntry<"logs"> | CollectionEntry<"misc">;
  headings: MarkdownHeading[];
  tocDefault: boolean;
  section: string;
}
const { post, headings, tocDefault, section } = Astro.props;
const fm = post.data;
const title = titleOf(post);

const words = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.round(words / 200));

const updated =
  fm.lastmod && (!fm.date || iso(fm.lastmod) !== iso(fm.date));
const tocOn = fm.toc ?? tocDefault;
---
<BaseLayout title={title} section={section}>
  <article class="post">
    <header class="post-head">
      <h1>{title}</h1>
      <div class="post-meta">
        {fm.date && <time datetime={iso(fm.date)}>{iso(fm.date)}</time>}
        {updated && (
          <Fragment>
            {fm.date ? " · updated " : "updated "}
            <time datetime={iso(fm.lastmod!)}>{iso(fm.lastmod!)}</time>
          </Fragment>
        )}
        {`${fm.date || updated ? " · " : ""}${readingTime} min read`}
      </div>
    </header>

    {tocOn && <Toc headings={headings} />}

    <div class="prose"><slot /></div>

    <footer class="post-foot"><Giscus /></footer>
  </article>

  <script>
    if (document.querySelector(".mermaid")) {
      import(
        "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs"
      ).then(({ default: mermaid }) =>
        mermaid.initialize({
          startOnLoad: true,
          theme: "dark",
          securityLevel: "loose",
        }),
      );
    }
  </script>
</BaseLayout>
